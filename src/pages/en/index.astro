---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import Hero from '../../components/Hero.astro';
import Obligation from '../../components/Obligation.astro';
import Existence from '../../components/Existence.astro';
import Anomaly from '../../components/Anomaly.astro';
import MissingLink from '../../components/MissingLink.astro';
import Conclusion from '../../components/Conclusion.astro';
import Timeline from '../../components/Timeline.astro';
import PostElectionAudits from '../../components/PostElectionAudits.astro';
import Context from '../../components/Context.astro';
import Irregularidades from '../../components/Irregularidades.astro';
import FAQ from '../../components/FAQ.astro';
import BackgroundCards from '../../components/BackgroundCards.astro';
import PostInauguration from '../../components/PostInauguration.astro';
import Impact from '../../components/Impact.astro';
import Share from '../../components/Share.astro';
import Footer from '../../components/Footer.astro';
import { getLangFromUrl, useTranslations } from '../../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<Layout title={t('hero_title')}>
	<Navbar />
	<main>
		<!-- §0 Thesis -->
		<Hero />

		<!-- 5-act argument -->
		<Obligation />
		<Existence />
		<Anomaly />
		<MissingLink />
		<Conclusion />

		<!-- Evidence detail (secondary) -->
		<Timeline />
		<PostElectionAudits />
		<Context />
		<Irregularidades />

		<!-- Support sections -->
		<FAQ />
		<BackgroundCards />
		<PostInauguration />
		<Impact />
		<Share />
	</main>

	<Footer />
</Layout>
