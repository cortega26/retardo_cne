---
import { getLangFromUrl, useTranslations } from '../i18n/utils';

export interface Props {
  sources: { text: string; url?: string }[];
  label?: string;
}

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const { sources, label } = Astro.props;
const heading = label ?? t('sources_label');
---

<div class="source-list">
  <span class="source-list-label">{heading}</span>
  <ul class="source-list-items">
    {sources.map((source) => (
      <li class="source-list-item">
        {source.url ? (
          <a href={source.url} target="_blank" rel="noopener noreferrer" class="story-link">{source.text}</a>
        ) : (
          <span>{source.text}</span>
        )}
      </li>
    ))}
  </ul>
</div>

<style>
  .source-list {
    font-size: 0.875rem;
    color: var(--text-secondary);
    border-top: 1px solid var(--border-subtle);
    padding-top: 1rem;
    margin-top: 1rem;
  }
  .source-list-label {
    font-weight: 700;
    margin-right: 0.5rem;
    color: var(--text-accent);
  }
  .source-list-items {
    display: inline;
    list-style: none;
    padding: 0;
    margin: 0;
  }
  .source-list-item {
    display: inline;
  }
  .source-list-item:not(:last-child)::after {
    content: " • ";
    margin: 0 0.25rem;
  }
</style>
