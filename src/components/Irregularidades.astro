---
import { getCollection } from 'astro:content';
import { getLangFromUrl, useTranslations } from '../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const allIrregularidades = (await getCollection('irregularidades'))
  .filter(item => item.id.startsWith(`${lang}/`))
  .sort((a, b) => a.data.id - b.data.id);
---

<section id="analisis" class="story-section max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 my-12">
  <div class="text-center mb-12">
    <span class="section-label">{t('badge_analysis')}</span>
    <h3 class="uppercase font-bold mb-6">{t('nav_analysis_irregularities')}</h3>
    <p class="story-subtitle">{t('analysis_subtitle')}</p>
  </div>

  <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
    {allIrregularidades.map((item) => (
      <div>
        <div class="story-card h-full flex flex-col">

          <!-- Card header -->
          <div class="flex items-center justify-between mb-6 flex-wrap gap-2">
            <span class="story-kicker mb-0">
              {t('badge_case')}{item.data.id}
            </span>
            <span class={`status-tag ${item.data.replica ? 'status-tag-met' : 'status-tag-failed'}`}>
              {item.data.replica ? t('badge_official_response') : t('badge_observation')}
            </span>
          </div>

          <!-- Title -->
          <h3 class="text-lg font-semibold mb-6" style="color: var(--text-primary);">{item.data.title}</h3>

          <!-- Content rows -->
          <div class="flex-1">
            <div class="grid grid-cols-1 md:grid-cols-2 gap-3">
              <div>
                <div class="label-heading mb-2">{t('irreg_afirmacion')}</div>
                <p class="text-sm mb-0" style="line-height: 1.6; color: var(--text-secondary);">{item.data.afirmacion}</p>
              </div>
              <div>
                <div class="label-heading mb-2">{t('irreg_norma')}</div>
                <p class="text-sm mb-0 italic" style="line-height: 1.6; color: var(--text-secondary);">{item.data.norma}</p>
              </div>
              <div class="md:col-span-2" style="border-top: 1px solid var(--border-subtle); padding-top: 1rem; margin-top: 0.5rem;">
                <div class="label-heading mb-2">{t('irreg_evidencia')}</div>
                <p class="text-sm mb-0" style="line-height: 1.6; color: var(--text-secondary);">{item.data.evidencia}</p>
              </div>
              <div class="md:col-span-2">
                <div class="label-heading mb-2" style="color: var(--color-danger);">{t('irreg_impacto')}</div>
                <p class="text-sm font-medium mb-0" style="line-height: 1.6; color: var(--color-danger); opacity: 0.85;">{item.data.impacto}</p>
              </div>
            </div>
          </div>

          {item.data.replica && (
            <div class="mt-4 pt-4" style="border-top: 1px solid var(--border-subtle);">
              <div class="label-heading mb-2" style="color: var(--text-accent);">{t('irreg_replica')}</div>
              <p class="small mb-0" style="line-height: 1.6; color: var(--text-secondary);">{item.data.replica}</p>
            </div>
          )}
        </div>
      </div>
    ))}
  </div>
</section>

<style>
  .label-heading {
    font-size: 0.75rem;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--text-accent);
  }
</style>
