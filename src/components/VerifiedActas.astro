---
import { getLangFromUrl, useTranslations } from '../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const stats = [
  { label: t('verified_minutes_label'), value: '83.5%', sub: t('verified_minutes_sub') },
  { label: t('verified_volunteers_label'), value: '1M+', sub: t('verified_volunteers_sub') },
  { label: t('verified_macedonia_label'), value: '100%', sub: t('verified_macedonia_sub') }
];
---

<section id="actas" class="story-section container my-5">
  <div class="text-center mb-5">
    <span class="country-tag mb-3 d-inline-block">{t('badge_actas')}</span>
    <h3 class="text-uppercase fw-bold mb-3">{t('nav_verification_section')}</h3>
    <p class="story-subtitle">{t('verified_actas_subtitle')}</p>
  </div>

  <!-- Stats -->
  <div class="row g-4 mb-5">
    {stats.map(stat => (
      <div class="col-md-4">
        <div class="story-card h-100 text-center">
          <h3 class="fw-bold mb-2" style="font-size: 3rem; font-family: var(--font-mono); color: var(--text-accent);">{stat.value}</h3>
          <p class="small mb-1 text-uppercase" style="letter-spacing: 0.1em; color: var(--text-secondary);">{stat.label}</p>
          <p class="small fw-bold mb-0" style="color: var(--text-primary);">{stat.sub}</p>
        </div>
      </div>
    ))}
  </div>

  <!-- CTA Card -->
  <div class="story-card" style="background: rgba(15, 94, 168, 0.04); border-color: rgba(15, 94, 168, 0.2);">
    <div class="row align-items-center">
      <div class="col-lg-7">
        <h4 class="fw-bold mb-3" style="color: var(--text-primary);">{t('verified_cta_title')}</h4>
        <p style="color: var(--text-secondary); margin-bottom: 0;">{t('verified_cta_text')}</p>
      </div>
      <div class="col-lg-5 text-lg-end mt-4 mt-lg-0">
        <a href="https://resultadosconvzla.com/" target="_blank" rel="noopener noreferrer" class="btn btn-primary fw-bold px-5 py-3">
          <i class="fas fa-external-link-alt me-2"></i>{t('verified_cta_btn')}
        </a>
      </div>
    </div>
  </div>
</section>
