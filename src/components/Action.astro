---
import { getLangFromUrl, useTranslations } from '../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<section id="accion" class="story-section max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 my-12" aria-label={t('nav_action')}>
  <div class="story-card text-center" style="background: linear-gradient(135deg, rgba(15, 94, 168, 0.07) 0%, rgba(15, 94, 168, 0.02) 100%); box-shadow: var(--shadow-card), 0 0 0 1px rgba(15, 94, 168, 0.28);">
    <div class="mb-4">
      <span class="section-label">{t('badge_share')}</span>
    </div>
    <h2 class="font-bold mb-6" style="font-family: var(--font-heading); color: var(--text-primary);">{t('action_title')}</h2>
    <p class="mb-5 mx-auto" style="max-width: 600px; line-height: 1.7; color: var(--text-secondary);">
      {t('action_text')}
    </p>

    <div class="flex flex-wrap justify-center gap-3">
      <a href="#compartir" class="btn btn-primary font-bold px-5 py-3">
        <svg class="icon me-2" viewBox="0 0 448 512" aria-hidden="true" width="1em" height="1em"><path d="M352 320c-22.6 0-43 8.6-58.6 22.5l-130.5-78.3c1-5.3 1.6-10.8 1.6-16.4s-.5-11-1.6-16.4l130.5-78.3C309 183.4 329.4 192 352 192c53 0 96-43 96-96S405 0 352 0s-96 43-96 96c0 5.5.5 11 1.6 16.4L127 190.7C111.5 176.8 91.1 168 68.5 168c-53 0-96 43-96 96s43 96 96 96c22.6 0 43-8.8 58.6-22.7l130.5 78.3c-1 5.3-1.6 10.8-1.6 16.4 0 53 43 96 96 96s96-43 96-96-43-96-96-96z"/></svg>{t('action_share_btn')}
      </a>
      <a href="https://resultadosconvzla.com/" target="_blank" rel="noopener noreferrer"
         class="btn btn-outline-primary font-bold px-5 py-3">
        <svg class="icon me-2" viewBox="0 0 384 512" aria-hidden="true" width="1em" height="1em"><path d="M192 0c-16.6 0-30.3 11-34.6 26H48C21.5 26 0 47.5 0 74v352c0 26.5 21.5 48 48 48h288c26.5 0 48-21.5 48-48V74c0-26.5-21.5-48-48-48h-109.4c-4.3-15-18-26-34.6-26zm0 28c6.6 0 12 5.4 12 12s-5.4 12-12 12-12-5.4-12-12 5.4-12 12-12zm-86.2 328.5l-48-52.5c-4.1-4.5-3.8-11.6.6-15.7 4.5-4.1 11.5-3.8 15.7.6l39.8 43.6 95.2-100c4.3-4.5 11.3-4.7 15.8-.4 4.5 4.3 4.7 11.3.4 15.8l-103 108.1c-4.5 5-11.8 5.1-16.5.1z"/></svg>{t('action_actas_btn')}
      </a>
      <a href="https://foropenal.com/" target="_blank" rel="noopener noreferrer"
         class="btn btn-outline-primary font-bold px-5 py-3">
        <svg class="icon me-2" viewBox="0 0 448 512" aria-hidden="true" width="1em" height="1em" fill="currentColor"><path d="M224 256A128 128 0 1 0 224 0a128 128 0 1 0 0 256zm-45.7 48C79.8 304 0 383.8 0 482.3C0 498.7 13.3 512 29.7 512l388.6 0c16.4 0 29.7-13.3 29.7-29.7C448 383.8 368.2 304 269.7 304l-91.4 0z"/></svg>{t('action_support_btn')}
      </a>
    </div>
  </div>
</section>
