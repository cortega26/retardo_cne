---
import { getLangFromUrl, useTranslations } from '../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<section id="accion" class="story-section container my-5">
  <div class="story-card text-center" style="background: linear-gradient(135deg, rgba(15, 94, 168, 0.07) 0%, rgba(15, 94, 168, 0.02) 100%); box-shadow: var(--shadow-card), 0 0 0 1px rgba(15, 94, 168, 0.28);">
    <div class="mb-4">
      <span class="country-tag d-inline-block mb-3">{t('badge_share')}</span>
    </div>
    <h2 class="fw-bold mb-4" style="font-family: var(--font-heading); color: var(--text-primary);">{t('action_title')}</h2>
    <p class="mb-5 mx-auto" style="max-width: 600px; line-height: 1.7; color: var(--text-secondary);">
      {t('action_text')}
    </p>

    <div class="d-flex flex-wrap justify-content-center gap-3">
      <a href="#compartir" class="btn btn-primary fw-bold px-5 py-3">
        <svg class="icon me-2" viewBox="0 0 448 512" aria-hidden="true" width="1em" height="1em"><path d="M352 320c-22.6 0-43 8.6-58.6 22.5l-130.5-78.3c1-5.3 1.6-10.8 1.6-16.4s-.5-11-1.6-16.4l130.5-78.3C309 183.4 329.4 192 352 192c53 0 96-43 96-96S405 0 352 0s-96 43-96 96c0 5.5.5 11 1.6 16.4L127 190.7C111.5 176.8 91.1 168 68.5 168c-53 0-96 43-96 96s43 96 96 96c22.6 0 43-8.8 58.6-22.7l130.5 78.3c-1 5.3-1.6 10.8-1.6 16.4 0 53 43 96 96 96s96-43 96-96-43-96-96-96z"/></svg>{t('action_share_btn')}
      </a>
      <a href="https://resultadosconvzla.com/" target="_blank" rel="noopener noreferrer"
         class="btn btn-outline-primary fw-bold px-5 py-3">
        <svg class="icon me-2" viewBox="0 0 384 512" aria-hidden="true" width="1em" height="1em"><path d="M192 0c-16.6 0-30.3 11-34.6 26H48C21.5 26 0 47.5 0 74v352c0 26.5 21.5 48 48 48h288c26.5 0 48-21.5 48-48V74c0-26.5-21.5-48-48-48h-109.4c-4.3-15-18-26-34.6-26zm0 28c6.6 0 12 5.4 12 12s-5.4 12-12 12-12-5.4-12-12 5.4-12 12-12zm-86.2 328.5l-48-52.5c-4.1-4.5-3.8-11.6.6-15.7 4.5-4.1 11.5-3.8 15.7.6l39.8 43.6 95.2-100c4.3-4.5 11.3-4.7 15.8-.4 4.5 4.3 4.7 11.3.4 15.8l-103 108.1c-4.5 5-11.8 5.1-16.5.1z"/></svg>{t('action_actas_btn')}
      </a>
      <a href="https://github.com/cortega26/retardo_cne" target="_blank" rel="noopener noreferrer"
         class="btn btn-outline-primary fw-bold px-5 py-3">
        <svg class="icon me-2" viewBox="0 0 496 512" aria-hidden="true" width="1em" height="1em"><path d="M165.9 397.4c0 2-2.3 3.6-5.2 3.6-3.3.3-5.6-1.3-5.6-3.6 0-2 2.3-3.6 5.2-3.6 3-.3 5.6 1.3 5.6 3.6zm-31.1-4.5c-.7 2 1.3 4.3 4.3 4.9 2.6 1 5.6 0 6.2-2s-1.3-4.3-4.3-5c-2.6-.7-5.5.3-6.2 2.1zm44.2-1.7c-2.9.7-4.9 2.6-4.6 4.9.3 2 2.9 3.3 5.9 2.6 2.9-.7 4.9-2.6 4.6-4.6-.3-1.9-3-3.2-5.9-2.9zM248 8C111 8 0 119 0 256c0 113 73.3 209 175.2 242.9 12.8 2.3 17.5-5.6 17.5-12.4 0-6.2-.3-22.6-.4-44.4-71.3 15.5-86.3-34.4-86.3-34.4-11.7-29.7-28.6-37.6-28.6-37.6-23.3-15.9 1.8-15.6 1.8-15.6 25.8 1.8 39.3 26.5 39.3 26.5 22.9 39.3 60.2 28 74.8 21.4 2.3-16.6 8.9-28 16.3-34.4-57-6.5-117-28.5-117-126.9 0-28 10-51 26.4-69-2.6-6.5-11.4-32.7 2.5-68.2 0 0 21.5-6.9 70.5 26.3 20.4-5.7 42.4-8.5 64.2-8.5s43.8 2.8 64.2 8.5c49-33.2 70.5-26.3 70.5-26.3 13.9 35.5 5.1 61.7 2.5 68.2 16.4 18.9 26.4 40.9 26.4 69 0 98.4-60 120.3-117.1 126.6 9.2 7.9 17.4 23.5 17.4 47.3 0 34.2-.3 61.7-.3 70.1 0 6.9 4.6 14.8 17.7 12.3C422.8 465 496 369 496 256 496 119 385 8 248 8z"/></svg>{t('action_github_btn')}
      </a>
    </div>
  </div>
</section>
