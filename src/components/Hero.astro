---
import { getLangFromUrl, useTranslations } from '../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const methodologyHref = lang === 'es' ? `${base}/metodologia` : `${base}/en/metodologia`;

// Art. 155 LOPRE: 30-day deadline expired August 29, 2024
const daysElapsed = Math.floor((Date.now() - new Date('2024-08-29').getTime()) / 86_400_000);
---

<header id="inicio" class="hero-shell">
  <div class="hero-inner">

    <div class="hero-eyebrow">
      <div class="country-tag">
        <span class="flag flag-venezuela" aria-hidden="true"></span>
        <span>{lang === 'es' ? 'Venezuela · 28J 2024' : 'Venezuela · July 28, 2024'}</span>
      </div>
      <div class="status-badge">
        <span class="status-dot"></span>
        <span>{t('status_violation')}</span>
      </div>
    </div>

    <div class="hero-contrast" aria-label={lang === 'es'
      ? 'CNE publicó 0 actas oficiales; ciudadanía publicó 25.575'
      : 'CNE published 0 official actas; citizens published 25,575'}>
      <div class="hero-num-block hero-num--zero">
        <span class="hero-big-num">0</span>
        <span class="hero-num-label">{t('hero_card1_cne_label')}</span>
      </div>
      <span class="hero-vs-divider" aria-hidden="true">vs</span>
      <div class="hero-num-block">
        <span id="hero-num-citizen" class="hero-big-num" data-final="25575" data-sep={lang === 'es' ? '.' : ','}>{lang === 'es' ? '25.575' : '25,575'}</span>
        <span class="hero-num-label">{t('hero_card1_citizen_label')}</span>
      </div>
    </div>

    <h1 class="hero-headline">{t('hero_title')}</h1>

    <div class="hero-verdict" role="note" aria-label={lang === 'es' ? 'Conclusión: el nombre de lo ocurrido' : 'Conclusion: what happened'}>
      <div class="hero-verdict-phase">
        <span class="hero-verdict-date">28J 2024</span>
        <strong class="hero-verdict-name">{t('hero_verdict_fraud')}</strong>
        <span class="hero-verdict-note">{t('hero_verdict_fraud_note')}</span>
      </div>
      <span class="hero-verdict-arrow" aria-hidden="true">→</span>
      <div class="hero-verdict-phase">
        <span class="hero-verdict-date">{lang === 'es' ? '10 ene 2025' : '10 Jan 2025'}</span>
        <strong class="hero-verdict-name">{t('hero_verdict_rupture')}</strong>
        <span class="hero-verdict-note">{t('hero_verdict_rupture_note')}</span>
      </div>
    </div>

    <p class="hero-days-strip">
      <strong class="hero-days-count">{daysElapsed}</strong>{' '}{t('hero_days_context')}
    </p>

    <div class="hero-actions">
      <a class="btn btn-primary" href="#obligacion">{t('hero_cta_primary')}</a>
      <a class="btn btn-ghost" href="#actas">{t('hero_cta_secondary')}</a>
    </div>

    <div class="hero-meta" role="note" aria-label={lang === 'es' ? 'Indicadores de credibilidad' : 'Credibility indicators'}>
      <span>{t('cred_docs').replace('{{count}}', '7')}</span>
      <span aria-hidden="true">·</span>
      <span>{t('cred_update').replace('{{date}}', '2026-06-06')}</span>
      <span aria-hidden="true">·</span>
      <a href={methodologyHref}>
        {t('cred_corrections')}
      </a>
    </div>

  </div>
</header>

<script>
  (function () {
    const el = document.getElementById('hero-num-citizen');
    if (!el) return;
    if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;

    const final = 25575;
    const sep = (el as HTMLElement).dataset.sep ?? '.';
    const duration = 1800;

    function fmt(n: number): string {
      return n.toString().replace(/\B(?=(\d{3})+(?!\d))/g, sep);
    }

    el.textContent = fmt(0);
    const start = performance.now();

    function tick(now: number): void {
      if (!el) return;
      const progress = Math.min((now - start) / duration, 1);
      const eased = 1 - Math.pow(1 - progress, 3);
      el.textContent = fmt(Math.round(eased * final));
      if (progress < 1) requestAnimationFrame(tick);
    }

    requestAnimationFrame(tick);
  })();
</script>

<style>
  /* Verdict block */
  .hero-verdict {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 0.75rem 1.5rem;
    margin: 1.1rem 0;
    padding: 1.1rem 1.35rem;
    border-radius: var(--radius-card);
    background: color-mix(in srgb, var(--color-breach-500) 6%, var(--bg-card, #fff));
    border: 1px solid color-mix(in srgb, var(--color-breach-500) 22%, transparent);
  }

  .hero-verdict-phase {
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
    flex: 1;
    min-width: 10rem;
  }

  .hero-verdict-date {
    font-family: var(--font-mono);
    font-size: 0.65rem;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--color-breach-600);
  }

  .hero-verdict-name {
    font-family: var(--font-display);
    font-size: clamp(1.15rem, 2.2vw, 1.55rem);
    font-weight: 800;
    letter-spacing: -0.02em;
    line-height: 1.1;
    color: var(--text-primary);
  }

  .hero-verdict-note {
    font-size: 0.75rem;
    color: var(--text-secondary);
    line-height: 1.4;
    margin-top: 0.1rem;
  }

  .hero-verdict-arrow {
    font-size: 1.5rem;
    color: var(--color-breach-400);
    flex-shrink: 0;
    align-self: center;
  }

  :global([data-theme="dark"]) .hero-verdict {
    background: color-mix(in srgb, var(--color-breach-500) 10%, transparent);
    border-color: color-mix(in srgb, var(--color-breach-400) 28%, transparent);
  }

  :global([data-theme="dark"]) .hero-verdict-date { color: var(--color-breach-300); }
  :global([data-theme="dark"]) .hero-verdict-name { color: #fff; }
  :global([data-theme="dark"]) .hero-verdict-note { color: #95a0bd; }
  :global([data-theme="dark"]) .hero-verdict-arrow { color: var(--color-breach-500); }

</style>
