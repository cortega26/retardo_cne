---
import { getLangFromUrl, useTranslations } from '../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

// Art. 155 LOPRE: 30-day deadline expired August 29, 2024
const daysElapsed = Math.floor((Date.now() - new Date('2024-08-29').getTime()) / 86_400_000);
---

<header id="inicio" class="hero-shell">
  <div class="hero-inner">

    <div class="hero-eyebrow">
      <div class="country-tag">
        <span class="flag flag-venezuela" aria-hidden="true"></span>
        <span>{lang === 'es' ? 'Venezuela · 28J 2024' : 'Venezuela · July 28, 2024'}</span>
      </div>
      <div class="status-badge">
        <span class="status-dot"></span>
        <span>{t('status_violation')}</span>
      </div>
    </div>

    <div class="hero-contrast" aria-label={lang === 'es'
      ? 'CNE publicó 0 actas oficiales; ciudadanía publicó 25.575'
      : 'CNE published 0 official actas; citizens published 25,575'}>
      <div class="hero-num-block hero-num--zero">
        <span class="hero-big-num">0</span>
        <span class="hero-num-label">{t('hero_card1_cne_label')}</span>
      </div>
      <span class="hero-vs-divider" aria-hidden="true">vs</span>
      <div class="hero-num-block">
        <span class="hero-big-num">{lang === 'es' ? '25.575' : '25,575'}</span>
        <span class="hero-num-label">{t('hero_card1_citizen_label')}</span>
      </div>
    </div>

    <h1 class="hero-headline">{t('hero_title')}</h1>

    <p class="hero-days-strip">
      <strong class="hero-days-count">{daysElapsed}</strong>{' '}{t('hero_days_context')}
    </p>

    <div class="hero-inauguration-note" role="note" aria-label={lang === 'es' ? 'Nota sobre la inauguración' : 'Inauguration note'}>
      <span class="hero-inau-pill" aria-hidden="true">{lang === 'es' ? '10 ENE 2025' : '10 JAN 2025'}</span>
      <span class="hero-inau-text">{t('hero_inauguration_note')}</span>
    </div>

    <div class="hero-actions">
      <a class="btn btn-primary" href="#obligacion">{t('hero_cta_primary')}</a>
      <a class="btn btn-ghost" href="#actas">{t('hero_cta_secondary')}</a>
    </div>

    <div class="hero-meta" role="note" aria-label={lang === 'es' ? 'Indicadores de credibilidad' : 'Credibility indicators'}>
      <span>{t('cred_docs').replace('{{count}}', '7')}</span>
      <span aria-hidden="true">·</span>
      <span>{t('cred_update').replace('{{date}}', '2026-06-06')}</span>
      <span aria-hidden="true">·</span>
      <a href="https://github.com/cortega26/retardo_cne/issues/new" target="_blank" rel="noopener noreferrer">
        {t('cred_corrections')}
      </a>
    </div>

  </div>
</header>

<style>
  .hero-inauguration-note {
    display: flex;
    align-items: baseline;
    flex-wrap: wrap;
    gap: 0.6rem;
    margin-top: 0.75rem;
    padding: 0.75rem 1.1rem;
    border-radius: 0.5rem;
    background: color-mix(in srgb, var(--color-breach-500) 8%, transparent);
    border: 1px solid color-mix(in srgb, var(--color-breach-500) 25%, transparent);
    border-left: 3px solid var(--color-breach-500);
    max-width: 62ch;
  }

  .hero-inau-pill {
    font-family: var(--font-mono);
    font-size: 0.68rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-breach-700);
    white-space: nowrap;
    flex-shrink: 0;
  }

  .hero-inau-text {
    font-size: 0.88rem;
    line-height: 1.5;
    color: var(--text-secondary);
  }

  :global([data-theme="dark"]) .hero-inauguration-note {
    background: color-mix(in srgb, var(--color-breach-500) 12%, transparent);
    border-color: color-mix(in srgb, var(--color-breach-400) 30%, transparent);
    border-left-color: var(--color-breach-400);
  }

  :global([data-theme="dark"]) .hero-inau-pill {
    color: var(--color-breach-300);
  }

  :global([data-theme="dark"]) .hero-inau-text {
    color: #c3cbe2;
  }
</style>
