---
import { getLangFromUrl, useTranslations } from '../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const heroCards = [
  {
    metric: lang === 'es' ? '25.575' : '25,575',
    title: t('hero_stat_1'),
    sources: [
      { label: t('source_label'), text: t('hero_stat_1_source_primary'), href: 'https://resultadosconvzla.com/' },
      { label: t('sources_label'), text: t('hero_stat_1_source_archive'), href: 'https://web.archive.org/web/20240726002936/http://www.cne.gob.ve/' },
    ],
  },
  {
    metric: '4',
    title: t('hero_stat_2'),
    sources: [
      { label: t('sources_label'), text: t('hero_stat_2_source_carter'), href: 'https://www.cartercenter.org/news/venezuela-073024/' },
      { label: '', text: t('hero_stat_2_source_un'), href: 'https://news.un.org/en/sites/news.un.org.en/files/atoms/files/Interim_Report_PoE_Venezuela_090824.pdf' },
      { label: '', text: lang === 'es' ? 'Union Europea' : 'European Union', href: 'https://www.consilium.europa.eu/es/press/press-releases/2024/08/04/venezuela-statement-by-the-high-representative-on-behalf-of-the-eu/' },
      { label: '', text: lang === 'es' ? 'OEA' : 'OAS', href: 'https://www.oas.org/es/centro_noticias/comunicado_prensa.asp?sCodigo=C-046/24' },
    ],
  },
  {
    metric: '48h',
    title: t('hero_stat_3'),
    sources: [
      { label: t('sources_label'), text: t('hero_stat_3_source_lopre'), href: 'https://pdba.georgetown.edu/Electoral/Venezuela/LOPE2009.pdf' },
      { label: '', text: t('hero_stat_3_source_audits'), href: 'https://web.archive.org/web/20240417122253/http://www.cne.gob.ve/web/sistema_electoral/tecnologia_electoral_auditorias.php' },
      { label: '', text: lang === 'es' ? 'Prensa Comunitaria' : 'Community Press', href: 'https://prensacomunitaria.org/2024/08/venezuela-las-auditorias-para-verificar-resultados-electorales-que-no-ha-hecho-el-cne/' },
    ],
  },
];
---

<header id="inicio" class="hero-shell">
  <div class="hero-grid container-fluid">
    <div class="hero-copy">
      <div class="hero-badges">
        <div class="country-tag">
          <span class="flag flag-venezuela" aria-hidden="true"></span>
          <span>{t('badge_herosub')}</span>
        </div>
        <div class="status-badge">
          <span class="status-dot"></span>
          <span>{t('status_violation')}</span>
        </div>
      </div>

      <p class="hero-suptitle">{t('hero_subtitle')}</p>
      <h1>{t('hero_title')}</h1>

      <div class="credibility-bar" role="note" aria-label="Indicadores de credibilidad">
        <span>{t('cred_docs').replace('{{count}}', '7')}</span>
        <span>{t('cred_update').replace('{{date}}', '2025-05-27')}</span>
        <a href="https://github.com/cortega26/retardo_cne/issues/new" target="_blank" rel="noopener noreferrer">
          {t('cred_corrections')}
        </a>
      </div>

      <div class="hero-actions">
        <a class="btn btn-primary hero-cta" href="#cronologia">{t('hero_cta_primary')}</a>
        <a class="btn btn-outline-primary hero-cta hero-cta-secondary" href="#verificacion">{t('hero_cta_secondary')}</a>
      </div>
    </div>

    <div class="hero-evidence" aria-label={lang === 'es' ? 'Panel de evidencia destacada' : 'Featured evidence panel'}>
      {heroCards.map((card) => (
        <article class="hero-note story-card">
          <p class="hero-note-metric">{card.metric}</p>
          <h2 class="hero-note-title">{card.title}</h2>
          <div class="hero-note-sources text-muted">
            {card.sources.map((source, index) => (
              <span>
                {source.label ? <strong>{source.label} </strong> : null}
                <a class="story-link" href={source.href} target="_blank" rel="noopener noreferrer">{source.text}</a>
                {index < card.sources.length - 1 ? <span class="source-divider" aria-hidden="true"> • </span> : null}
              </span>
            ))}
          </div>
        </article>
      ))}
    </div>
  </div>
</header>
