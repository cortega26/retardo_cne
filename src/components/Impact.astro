---
import { getLangFromUrl, useTranslations } from '../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const indicators = [
  {
    label: t('impact_indicator_1_label'),
    text: t('impact_indicator_1_text'),
    sourceLabel: lang === 'es' ? 'ACNUDH Sep. 2024 · HRW Venezuela 2025' : 'OHCHR Sept. 2024 · HRW Venezuela 2025',
    sourceUrl: 'https://news.un.org/en/sites/news.un.org.en/files/atoms/files/Interim_Report_PoE_Venezuela_090824.pdf'
  },
  {
    label: t('impact_indicator_2_label'),
    text: t('impact_indicator_2_text'),
    sourceLabel: lang === 'es' ? 'CIDH Res. 2/2024 · Art. 146 LOPRE' : 'IACHR Res. 2/2024 · Art. 146 LOPRE',
    sourceUrl: 'https://www.oas.org/en/iachr/decisions/2024/VERE2401EN.PDF'
  },
  {
    label: t('impact_indicator_3_label'),
    text: t('impact_indicator_3_text'),
    sourceLabel: lang === 'es' ? 'Declaración UE · OEA · Centro Carter' : 'EU Statement · OAS · Carter Center',
    sourceUrl: 'https://www.consilium.europa.eu/es/press/press-releases/2024/08/04/venezuela-statement-by-the-high-representative-on-behalf-of-the-eu/'
  }
];
---

<section id="impacto" class="story-section max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 my-12" aria-label={t('nav_context_impact_section')}>
  <div class="text-center mb-12">
    <span class="section-label">{t('badge_impact')}</span>
    <h3 class="uppercase font-bold mb-6">{t('nav_context_impact_section')}</h3>
    <p class="story-subtitle">{t('impact_subtitle')}</p>
  </div>

  <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
    {indicators.map((item) => (
      <div>
        <div class="story-card h-full text-center flex flex-col">
          <h4 class="text-base font-semibold uppercase mb-6" style="letter-spacing: 0.06em;">{item.label}</h4>
          <p class="text-sm mb-6 flex-1" style="color: var(--text-secondary); line-height: 1.6;">{item.text}</p>
          <div class="mt-auto pt-3" style="border-top: 1px solid var(--border-subtle);">
            <a href={item.sourceUrl} target="_blank" rel="noopener noreferrer" class="story-link text-sm">
              {item.sourceLabel} →
            </a>
          </div>
        </div>
      </div>
    ))}
  </div>

  <div class="impact-conclusion">
    <span class="impact-conclusion-kicker">{lang === 'es' ? 'La conclusión' : 'The bottom line'}</span>
    <h4 class="impact-conclusion-title">
      {lang === 'es' ? 'Una proclamación sin resultados es írrita' : 'A proclamation without results is void'}
    </h4>
    <p class="impact-conclusion-text">
      {lang === 'es'
        ? 'El CNE proclamó un resultado sin publicar las actas desagregadas que exige el Art. 146 de la LOPRE, y el TSJ lo validó el 22 de agosto de 2024 sin revisar una sola acta ni convocar a las partes. Sin resultados verificables no hay proclamación válida posible: lo ocurrido es una ruptura del hilo constitucional, un autogolpe consumado con la anuencia de los poderes públicos.'
        : 'The CNE proclaimed a result without publishing the per-table tally sheets required by Art. 146 of the LOPRE, and the TSJ validated it on 22 August 2024 without reviewing a single sheet or summoning the parties. Without verifiable results, no valid proclamation is possible: what happened is a breach of constitutional order — a self-coup carried out with the acquiescence of the public powers.'}
    </p>
    <div class="impact-conclusion-sources">
      <a href="https://pdba.georgetown.edu/Electoral/Venezuela/LOPE2009.pdf" target="_blank" rel="noopener noreferrer">Art. 146 LOPRE</a>
      <span aria-hidden="true">·</span>
      <a href="https://www.oas.org/en/iachr/decisions/2024/VERE2401EN.PDF" target="_blank" rel="noopener noreferrer">{lang === 'es' ? 'CIDH Res. 2/2024' : 'IACHR Res. 2/2024'}</a>
    </div>
  </div>

  <div class="story-card mt-6 text-center" style="background: rgba(15, 94, 168, 0.05); box-shadow: var(--shadow-card), 0 0 0 1px rgba(15, 94, 168, 0.28);">
    <p class="mb-0 font-medium" style="color: var(--text-accent);">
      {t('impact_footer_text')}
    </p>
  </div>
</section>

<style>
  .impact-conclusion {
    margin-top: 1.5rem;
    padding: clamp(1.5rem, 4vw, 2.5rem);
    border-radius: var(--radius-card);
    background: color-mix(in srgb, var(--color-brand-600) 7%, var(--bg-card));
    border: 1px solid color-mix(in srgb, var(--color-brand-500) 20%, transparent);
    border-left: 5px solid var(--color-breach-500);
  }
  .impact-conclusion-kicker {
    display: inline-block;
    font-family: var(--font-mono);
    font-size: 0.62rem;
    font-weight: 700;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--color-breach-600);
    border-top: 2px solid currentcolor;
    padding-top: 0.55rem;
    margin-bottom: 0.9rem;
    line-height: 1;
  }
  .impact-conclusion-title {
    font-family: var(--font-display);
    font-size: clamp(1.4rem, 3vw, 2rem);
    font-weight: 800;
    letter-spacing: -0.02em;
    line-height: 1.15;
    margin: 0.6rem 0 0.9rem;
    color: var(--text-primary);
  }
  .impact-conclusion-text {
    font-size: 1.05rem;
    line-height: 1.7;
    margin: 0;
    color: var(--text-secondary);
    max-width: 70ch;
  }
  .impact-conclusion-sources {
    margin-top: 1.1rem;
    font-family: var(--font-mono);
    font-size: 0.8rem;
    display: flex;
    flex-wrap: wrap;
    gap: 0.6rem;
    align-items: center;
  }
  .impact-conclusion-sources a { color: var(--color-brand-600); text-decoration: none; font-weight: 600; }
  .impact-conclusion-sources a:hover { text-decoration: underline; }

  :global([data-theme="dark"]) .impact-conclusion {
    background: var(--color-brand-950);
    border-color: transparent;
    color: #eef2fb;
  }
  :global([data-theme="dark"]) .impact-conclusion-kicker { color: var(--color-breach-300); }
  :global([data-theme="dark"]) .impact-conclusion-title { color: #fff; }
  :global([data-theme="dark"]) .impact-conclusion-text { color: #d4dbef; }
  :global([data-theme="dark"]) .impact-conclusion-sources a { color: var(--color-brand-200); }
</style>
