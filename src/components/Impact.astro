---
import { getLangFromUrl, useTranslations } from '../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const indicators = [
  { 
    label: t('impact_indicator_1_label'), 
    text: t('impact_indicator_1_text'),
    sourceLabel: 'HRW Venezuela 2024 / OHCHR Sept. 2024',
    sourceUrl: 'https://www.hrw.org/world-report/2025/country-chapters/venezuela'
  },
  { 
    label: t('impact_indicator_2_label'), 
    text: t('impact_indicator_2_text'),
    sourceLabel: 'IACHR — Res. 2/2024',
    sourceUrl: 'https://www.oas.org/en/iachr/decisions/2024/VERE2401EN.PDF'
  },
  { 
    label: t('impact_indicator_3_label'), 
    text: t('impact_indicator_3_text'),
    sourceLabel: 'OAS / UN / EU / Carter Center',
    sourceUrl: 'https://www.cartercenter.org/news/venezuela-073024/'
  }
];
---

<section id="impacto" class="story-section container my-5">
  <div class="text-center mb-5">
    <span class="country-tag mb-3 d-inline-block">{t('badge_impact')}</span>
    <h3 class="text-uppercase fw-bold mb-3">{t('nav_context_impact_section')}</h3>
    <p class="story-subtitle">{t('impact_subtitle')}</p>
  </div>

  <div class="row g-4">
    {indicators.map((item, index) => (
      <div class="col-lg-4">
        <div class="story-card h-100 text-center d-flex flex-column">
          <h4 class="h6 fw-bold text-uppercase mb-3" style="letter-spacing: 0.06em;">{item.label}</h4>
          <p class="small mb-4 flex-grow-1" style="color: var(--text-secondary); line-height: 1.6;">{item.text}</p>
          <div class="mt-auto pt-3" style="border-top: 1px solid var(--border-subtle);">
            <a href={item.sourceUrl} target="_blank" rel="noopener noreferrer" class="story-link small">
              {item.sourceLabel} →
            </a>
          </div>
        </div>
      </div>
    ))}
  </div>

  <div class="story-card mt-4 text-center" style="background: rgba(15, 94, 168, 0.05); box-shadow: var(--shadow-card), 0 0 0 1px rgba(15, 94, 168, 0.28);">
    <p class="mb-0 fw-medium" style="color: var(--text-accent);">
      {t('impact_footer_text')}
    </p>
  </div>
</section>
