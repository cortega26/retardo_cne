---
import { getLangFromUrl, useTranslations } from '../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const shareUrl = new URL(Astro.url.pathname, Astro.site ?? Astro.url).href;
const shareText = "Incumplimientos verificables del CNE - Transparencia Electoral 2024";
---

<section id="compartir" class="section-padding border-t border-subtle" aria-label={t('badge_share')}>
  <div class="w-full container-tight">
    <div class="share-card text-center">
      <span class="section-label">{t('badge_share')}</span>
      <h2 class="share-heading">{t('social_share_text')}</h2>
      <p class="share-sub">{lang === 'es' ? 'Comparte la evidencia verificable con tu red.' : 'Share the verifiable evidence with your network.'}</p>

      <div class="share-buttons">
        <!-- X / Twitter -->
        <a href={`https://twitter.com/intent/tweet?text=${encodeURIComponent(shareText)}&url=${encodeURIComponent(shareUrl)}`}
           target="_blank" rel="noopener noreferrer"
           class="share-btn share-btn-x"
           style="background:#000;color:#fff;"
           aria-label={lang === 'es' ? 'Compartir en X (Twitter)' : 'Share on X (Twitter)'}>
          <svg viewBox="0 0 512 512" aria-hidden="true" width="1em" height="1em" fill="currentColor"><path d="M389.2 48h70.6L305.6 224.2 487 464H345L233.7 318.6 106.5 464H35.8L200.7 275.5 26.8 48H172.4L272.9 180.9 389.2 48zM364.4 421.8h39.1L151.1 88h-42l255.3 333.8z"/></svg>
          <span>{lang === 'es' ? 'Compartir en X' : 'Share on X'}</span>
        </a>

        <!-- WhatsApp -->
        <a href={`https://wa.me/?text=${encodeURIComponent(shareText + " " + shareUrl)}`}
           target="_blank" rel="noopener noreferrer"
           class="share-btn share-btn-wa"
           style="background:#25d366;color:#fff;"
           aria-label={lang === 'es' ? 'Compartir en WhatsApp' : 'Share on WhatsApp'}>
          <svg viewBox="0 0 448 512" aria-hidden="true" width="1em" height="1em" fill="currentColor"><path d="M380.9 97.1C339 55.1 283.2 32 223.9 32c-122.4 0-222 99.6-222 222 0 39.1 10.2 77.3 29.6 111L0 480l117.7-30.9c32.4 17.7 69 27.1 106.1 27.1h.1c122.3 0 224.1-99.6 224.1-222 0-59.3-25.2-115-67.1-157zm-157 341.6c-33.2 0-65.7-8.9-94-25.7l-6.7-4-69.8 18.3L72 359.2l-4.4-7c-18.5-29.4-28.2-63.3-28.2-98.2 0-101.7 82.8-184.5 184.6-184.5 49.3 0 95.6 19.2 130.4 54.1 34.8 34.9 56.2 81.2 56.1 130.5 0 101.8-84.9 184.6-186.6 184.6zm101.2-138.2c-5.5-2.8-32.8-16.2-37.9-18-5.1-1.9-8.8-2.8-12.5 2.8-3.7 5.6-14.3 18-17.6 21.8-3.2 3.7-6.5 4.2-12 1.4-32.6-16.3-54-29.1-75.5-66-5.7-9.8 5.7-9.1 16.3-30.3 1.8-3.7.9-6.9-.5-9.7-1.4-2.8-12.5-30.1-17.1-41.2-4.5-10.8-9.1-9.3-12.5-9.5-3.2-.2-6.9-.2-10.6-.2-3.7 0-9.7 1.4-14.8 6.9-5.1 5.6-19.4 19-19.4 46.3 0 27.3 19.9 53.7 22.6 57.4 2.8 3.7 39.1 59.7 94.8 83.8 35.2 15.2 49 16.5 66.6 13.9 10.7-1.6 32.8-13.4 37.4-26.4 4.6-13 4.6-24.1 3.2-26.4-1.3-2.5-5-3.9-10.5-6.6z"/></svg>
          <span>WhatsApp</span>
        </a>

        <!-- Telegram -->
        <a href={`https://t.me/share/url?url=${encodeURIComponent(shareUrl)}&text=${encodeURIComponent(shareText)}`}
           target="_blank" rel="noopener noreferrer"
           class="share-btn share-btn-tg"
           style="background:#0088cc;color:#fff;"
           aria-label={lang === 'es' ? 'Compartir en Telegram' : 'Share on Telegram'}>
          <svg viewBox="0 0 496 512" aria-hidden="true" width="1em" height="1em" fill="currentColor"><path d="M248 8C111 8 0 119 0 256s111 248 248 248 248-111 248-248S385 8 248 8zm121.8 169.9l-40.7 191.8c-3 13.6-11.1 16.9-22.4 10.5l-62-45.7-29.9 28.8c-3.3 3.3-6.1 6.1-12.5 6.1l4.4-63.1 114.9-103.8c5-4.5-1.1-7-7.8-2.8l-141.9 89.4-61.2-19.1c-13.3-4.2-13.6-13.3 2.8-19.7l239.1-92.2c11.1-4.1 20.8 2.7 17.2 19.5z"/></svg>
          <span>Telegram</span>
        </a>

        <!-- LinkedIn -->
        <a href={`https://www.linkedin.com/sharing/share-offsite/?url=${encodeURIComponent(shareUrl)}`}
           target="_blank" rel="noopener noreferrer"
           class="share-btn share-btn-li"
           style="background:#0a66c2;color:#fff;"
           aria-label={lang === 'es' ? 'Compartir en LinkedIn' : 'Share on LinkedIn'}>
          <svg viewBox="0 0 448 512" aria-hidden="true" width="1em" height="1em" fill="currentColor"><path d="M100.3 448H7.4V148.9h92.9V448zM53.8 108.1C24.1 108.1 0 83.5 0 53.8a53.8 53.8 0 0 1 107.6 0c0 29.7-24.1 54.3-53.8 54.3zM447.9 448h-92.7V302.4c0-34.7-.7-79.2-48.3-79.2-48.3 0-55.7 37.7-55.7 76.7V448h-92.8V148.9h89.1v40.8h1.3c12.4-23.5 42.7-48.3 87.9-48.3 94 0 111.3 61.9 111.3 142.3V448z"/></svg>
          <span>LinkedIn</span>
        </a>

        <!-- Copy link -->
        <button id="copyLinkBtn" class="share-btn share-btn-copy"
                aria-label={lang === 'es' ? 'Copiar enlace' : 'Copy link'}>
          <svg viewBox="0 0 512 512" aria-hidden="true" width="1em" height="1em" fill="currentColor"><path d="M326.6 185.4c59.7 59.7 59.7 156.5 0 216.2l-84.9 84.9c-59.7 59.7-156.5 59.7-216.2 0s-59.7-156.5 0-216.2l41.4-41.4c4.7-4.7 12.3-4.7 17 0l17 17c4.7 4.7 4.7 12.3 0 17L59.4 327.9c-41 41-41 107.3 0 148.3 41 41 107.3 41 148.3 0l84.9-84.9c41-41 41-107.3 0-148.3l-17-17c-4.7-4.7-4.7-12.3 0-17l17-17c4.7-4.7 12.3-4.7 17 0l17 17zm-141.2 141.2c-59.7-59.7-59.7-156.5 0-216.2l84.9-84.9c59.7-59.7 156.5-59.7 216.2 0s59.7 156.5 0 216.2l-41.4 41.4c-4.7 4.7-12.3 4.7-17 0l-17-17c-4.7-4.7-4.7-12.3 0-17l41.4-41.4c41-41 41-107.3 0-148.3-41-41-107.3-41-148.3 0l-84.9 84.9c-41 41-41 107.3 0 148.3l17 17c4.7 4.7 4.7 12.3 0 17l-17 17c-4.7 4.7-12.3 4.7-17 0l-17-17z"/></svg>
          <span id="copyBtnLabel">{lang === 'es' ? 'Copiar enlace' : 'Copy link'}</span>
        </button>
      </div>
    </div>
  </div>
</section>

<style>
  .border-subtle { border-color: var(--border-subtle); }

  .share-card {
    background: var(--bg-card);
    border: 1px solid var(--border-subtle);
    border-radius: var(--radius-lg, 0.75rem);
    box-shadow: var(--shadow-card);
    padding: clamp(2rem, 5vw, 3.5rem);
  }

  .share-heading {
    font-size: clamp(1.4rem, 3vw, 2rem);
    font-weight: 800;
    color: var(--text-primary);
    letter-spacing: -0.02em;
    margin-bottom: 0.75rem;
    line-height: 1.2;
  }

  .share-sub {
    color: var(--text-secondary);
    font-size: 0.95rem;
    margin-bottom: 2rem;
    max-width: 55ch;
    margin-inline: auto;
    line-height: 1.6;
  }

  .share-buttons {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 0.75rem;
  }

  .share-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.65rem 1.4rem;
    border-radius: 999px;
    font-size: 0.875rem;
    font-weight: 600;
    text-decoration: none;
    border: 1px solid transparent;
    cursor: pointer;
    white-space: nowrap;
    font-family: inherit;
  }

  .share-btn svg { width: 1rem; height: 1rem; }

  /* X / Twitter */
  .share-btn-x {
    background: #000;
    color: #fff;
  }

  /* WhatsApp */
  .share-btn-wa {
    background: #25d366;
    color: #fff;
  }

  /* Telegram */
  .share-btn-tg {
    background: #0088cc;
    color: #fff;
  }

  /* LinkedIn */
  .share-btn-li {
    background: #0a66c2;
    color: #fff;
  }

  /* Copy link — ghost style */
  .share-btn-copy {
    background: transparent;
    color: var(--text-primary);
    border-color: var(--border-subtle);
  }

  body.dark-mode .share-btn-copy {
    border-color: var(--border-subtle);
  }
</style>
