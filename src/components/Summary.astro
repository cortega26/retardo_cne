---
import { getLangFromUrl, useTranslations } from '../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const methodologyHref = lang === 'es' ? `${base}/metodologia` : `${base}/en/metodologia`;
---

<!-- Methodology callout (matches live site structure) -->
<section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 my-8" aria-label={lang === 'es' ? 'Metodología de verificación' : 'Verification Methodology'}>
  <div class="story-card text-center">
    <p class="story-kicker">{lang === 'es' ? 'Metodología de verificación' : 'Verification Methodology'}</p>
    <p class="mb-2">{t('methodology_text')}</p>
    <a class="story-link" href={methodologyHref}>{t('methodology_link')} →</a>
  </div>
</section>

<!-- Mission statement (matches live site structure) -->
<section class="mission-statement max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center my-12" aria-label={lang === 'es' ? 'Declaración de la misión' : 'Mission statement'}>
  <p class="lead">
    {t('mission_text')}
  </p>
  <div class="mission-proof">
    <span class="mission-proof-label">{t('mission_proof_label')}</span>
    <a class="mission-proof-link" href="https://web.archive.org/web/20240726002936/http://www.cne.gob.ve/"
      target="_blank" rel="noopener noreferrer">{t('mission_proof_link')}</a>
  </div>
</section>
