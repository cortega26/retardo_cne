---
import { getLangFromUrl, useTranslations } from '../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const langToggleUrl = lang === 'es' ? '/retardo_cne/en/' : '/retardo_cne/';
const langToggleLabel = lang === 'es' ? 'EN' : 'ES';
const langToggleTarget = lang === 'es' ? 'en' : 'es';
const brandLabel = lang === 'es' ? 'Observatorio electoral ciudadano' : 'Citizen electoral observatory';

const navGroups = {
  evidence: {
    href: '#cronologia',
    label: t('nav_evidence'),
  },
  context: {
    href: '#sistema',
    label: t('nav_context'),
  },
  verification: {
    href: '#verificacion',
    label: t('nav_verification'),
  },
};
---

<nav class="navbar navbar-expand-lg" aria-label={lang === 'es' ? 'Navegación principal' : 'Main navigation'}>
  <div class="container-fluid">
    <a class="navbar-brand" href="#inicio" aria-current="page">
      <span class="brand-mark">{brandLabel}</span>
      <span class="brand-title">RETARDO <span class="brand-accent">CNE</span></span>
    </a>
    <button class="navbar-toggler custom-toggler" type="button" data-toggle="navbar-collapse"
      aria-controls="navbarNav" aria-expanded="false" aria-label="Toggle navigation">
      <span class="toggler-icon"></span>
      <span class="toggler-icon"></span>
      <span class="toggler-icon"></span>
    </button>
    <div class="collapse navbar-collapse" id="navbarNav">
      <ul class="navbar-nav me-auto mb-2 lg:mb-0">

        <!-- EVIDENCIA dropdown -->
        <li class="nav-item dropdown nav-item-split">
          <a class="nav-link nav-link-primary" href={navGroups.evidence.href}>
            {navGroups.evidence.label}
          </a>
          <button class="nav-link dropdown-toggle dropdown-toggle-split nav-link-toggle" type="button" id="evidenceDropdown" data-toggle="dropdown" aria-expanded="false" aria-label={`${navGroups.evidence.label} menu`}>
            <span class="visually-hidden">{navGroups.evidence.label}</span>
          </button>
          <ul class="dropdown-menu" aria-labelledby="evidenceDropdown">
            <li><a class="dropdown-item" href="#cronologia">{t('nav_evidence_timeline')}</a></li>
            <li><a class="dropdown-item" href="#auditorias">{t('nav_evidence_audits')}</a></li>
            <li><a class="dropdown-item" href="#analisis-tecnico">{t('nav_evidence_analysis')}</a></li>
            <li><a class="dropdown-item" href="#actas">{t('nav_evidence_actas')}</a></li>
            <li><hr class="dropdown-divider"></li>
            <li><span class="dropdown-header">{t('nav_evidence_results_header')}</span></li>
            <li><a class="dropdown-item" href="https://resultadosconvzla.com/" target="_blank" rel="noopener noreferrer">{t('nav_results_actas')}</a></li>
            <li><a class="dropdown-item" href="https://macedoniadelnorte.com/" target="_blank" rel="noopener noreferrer">{t('nav_results_macedonia')}</a></li>
            <li><hr class="dropdown-divider"></li>
            <li><span class="dropdown-header">{t('nav_evidence_analysis')}</span></li>
            <li><a class="dropdown-item" href="https://terrytao.wordpress.com/2024/08/02/what-are-the-odds-ii-the-venezuelan-presidential-election/" target="_blank" rel="noopener noreferrer">Dr. Terence Tao (UCLA)</a></li>
            <li><a class="dropdown-item" href="https://dorothykronick.com/28J.pdf" target="_blank" rel="noopener noreferrer">Dorothy Kronick (UC Berkeley)</a></li>
            <li><a class="dropdown-item" href="https://statmodeling.stat.columbia.edu/2024/07/31/suspicious-data-pattern-in-recent-venezuelan-election/" target="_blank" rel="noopener noreferrer">Andrew Gelman (Columbia U.)</a></li>
            <li><a class="dropdown-item" href="https://websites.umich.edu/~wmebane/Venezuela2024.pdf" target="_blank" rel="noopener noreferrer">Walter Mebane (U. of Michigan)</a></li>
          </ul>
        </li>

        <!-- CONTEXTO dropdown -->
        <li class="nav-item dropdown nav-item-split">
          <a class="nav-link nav-link-primary" href={navGroups.context.href}>
            {navGroups.context.label}
          </a>
          <button class="nav-link dropdown-toggle dropdown-toggle-split nav-link-toggle" type="button" id="contextDropdown" data-toggle="dropdown" aria-expanded="false" aria-label={`${navGroups.context.label} menu`}>
            <span class="visually-hidden">{navGroups.context.label}</span>
          </button>
          <ul class="dropdown-menu" aria-labelledby="contextDropdown">
            <li><a class="dropdown-item" href="#sistema">{t('nav_context_system')}</a></li>
            <li><a class="dropdown-item" href="#plazos">{t('nav_context_deadlines')}</a></li>
            <li><a class="dropdown-item" href="#antecedentes">{t('nav_context_background_section')}</a></li>
            <li><a class="dropdown-item" href="#impacto">{t('nav_context_impact_section')}</a></li>
          </ul>
        </li>

        <!-- VERIFICACIÓN dropdown -->
        <li class="nav-item dropdown nav-item-split">
          <a class="nav-link nav-link-primary" href={navGroups.verification.href}>
            {navGroups.verification.label}
          </a>
          <button class="nav-link dropdown-toggle dropdown-toggle-split nav-link-toggle" type="button" id="verificationDropdown" data-toggle="dropdown" aria-expanded="false" aria-label={`${navGroups.verification.label} menu`}>
            <span class="visually-hidden">{navGroups.verification.label}</span>
          </button>
          <ul class="dropdown-menu" aria-labelledby="verificationDropdown">
            <li><a class="dropdown-item" href="#actas">{t('nav_verification_how')}</a></li>
            <li><a class="dropdown-item" href="#verificacion">{t('nav_verification_section')}</a></li>
          </ul>
        </li>
      </ul>

      <!-- Right-side controls -->
      <div class="nav-controls flex items-center gap-2 ms-auto">
        <!-- Language Toggle -->
        <a id="toggleLang" href={langToggleUrl} class="btn btn-outline-primary btn-sm font-bold px-3" data-target-lang={langToggleTarget}>
          <span class="lang-code">{langToggleLabel}</span>
        </a>

        <!-- Theme Toggle -->
        <button id="toggleTheme" class="btn btn-outline-primary btn-sm nav-theme-toggle px-3" type="button" aria-label={t('nav_toggle_theme')} title={t('nav_toggle_theme')} aria-pressed="false">
          <svg class="icon icon-sun" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="16" height="16">
            <circle cx="12" cy="12" r="5"/><line x1="12" y1="1" x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/>
            <line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/>
            <line x1="1" y1="12" x2="3" y2="12"/><line x1="21" y1="12" x2="23" y2="12"/>
            <line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/>
          </svg>
          <svg class="icon icon-moon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="16" height="16">
            <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
          </svg>
        </button>

        <!-- Action CTA -->
        <a href="#accion" class="btn btn-primary btn-sm font-bold px-4">{t('nav_action')}</a>
      </div>
    </div>
  </div>
</nav>

<style>
  .navbar-brand {
    display: grid;
    gap: 0.15rem;
  }

  .brand-mark {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--text-secondary);
  }

  .brand-title {
    line-height: 1;
  }

  .brand-accent {
    color: var(--text-accent);
  }

  .nav-item-split {
    display: flex;
    align-items: stretch;
    position: relative;
  }

  .nav-item-split .nav-link-primary {
    padding-right: 0.35rem;
  }

  .nav-item-split .nav-link-toggle {
    padding-left: 0.35rem;
    min-width: 44px;
    min-height: 44px;
    border: 0;
    background: transparent;
    display: inline-flex;
    align-items: center;
    justify-content: center;
  }

  .nav-item-split .dropdown-toggle::after {
    margin-left: 0;
  }

  .nav-theme-toggle {
    min-height: 44px;
  }

  @media (max-width: 991.98px) {
    .nav-item-split {
      display: grid;
      grid-template-columns: minmax(0, 1fr) auto;
      align-items: center;
    }

    .navbar-brand {
      max-width: min(14rem, calc(100vw - 10rem));
    }

    .nav-item-split .nav-link-primary,
    .nav-item-split .nav-link-toggle {
      padding-top: 0.75rem;
      padding-bottom: 0.75rem;
    }
  }
</style>
