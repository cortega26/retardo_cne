---
import { getLangFromUrl, useTranslations } from '../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<footer style="background: var(--bg-card); border-top: 1px solid var(--border-subtle); padding: 3rem 0;">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
      <div class="text-center lg:text-left">
        <h2 class="text-lg font-semibold mb-6" style="font-family: var(--font-heading);">
          RETARDO <span style="color: var(--text-accent);">CNE</span>
        </h2>
        <p class="text-gray-500 mb-1 text-sm" style="max-width: 440px; line-height: 1.6;">
          &copy; 2024–2026 {t('footer_rights')}
          <br/>
          {t('footer_built_by')} <a href="https://tooltician.com/" target="_blank" rel="noopener noreferrer" style="color: var(--text-accent); text-decoration: none; font-weight: 500;">Tooltician</a>
        </p>
        <div style="margin-top: 1rem; font-size: 0.78rem; line-height: 1.6; color: var(--text-secondary); max-width: 480px;">
          <p style="margin: 0 0 0.35rem;">
            {t('footer_disclaimer')}
          </p>
          <p style="margin: 0;">
            <a href="https://github.com/cortega26/retardo_cne/issues/new" target="_blank" rel="noopener noreferrer" style="color: var(--text-accent);">{t('footer_report_correction')}</a>
            <span aria-hidden="true"> · </span>
            CC BY 4.0
            <span aria-hidden="true"> · </span>
            {t('cred_update').replace('{{date}}', '2025-05-27')}
          </p>
        </div>
      </div>
      <div class="text-center lg:text-right">
        <div class="flex flex-wrap justify-center lg:justify-end gap-3 items-center">
          <a href="https://github.com/cortega26/retardo_cne" target="_blank" rel="noopener noreferrer"
             class="btn btn-outline-primary btn-sm font-bold">
            <svg viewBox="0 0 16 16" fill="currentColor" width="14" height="14" style="margin-right:0.35rem;vertical-align:-2px;" aria-hidden="true"><path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.013 8.013 0 0016 8c0-4.42-3.58-8-8-8z"/></svg>
            {t('footer_opensource')}
          </a>
        </div>
      </div>
    </div>
    <div class="mt-6 pt-6" style="border-top: 1px solid var(--border-subtle);">
      <div class="flex justify-center gap-4 text-gray-500" style="font-size: 0.7rem; font-family: var(--font-mono); text-transform: uppercase; letter-spacing: 0.1em;">
        <a href="#inicio" class="story-link">{t('nav_home')}</a>
        <a href="#cronologia" class="story-link">{t('nav_evidence')}</a>
        <a href="#sistema" class="story-link">{t('nav_context')}</a>
      </div>
    </div>
  </div>
</footer>
