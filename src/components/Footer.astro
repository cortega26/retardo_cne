---
import { getLangFromUrl, useTranslations } from '../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<footer style="background: var(--bg-card); border-top: 1px solid var(--border-subtle); padding: 3rem 0;">
  <div class="container">
    <div class="row g-4 align-items-center">
      <div class="col-lg-6 text-center text-lg-start">
        <h2 class="h5 fw-bold mb-3" style="font-family: var(--font-heading);">
          RETARDO <span style="color: var(--text-accent);">CNE</span>
        </h2>
        <p class="text-muted mb-0 small" style="max-width: 440px; line-height: 1.6;">
          &copy; 2024–2026 {t('footer_rights')}
        </p>
      </div>
      <div class="col-lg-6 text-center text-lg-end">
        <div class="d-flex flex-wrap justify-content-center justify-content-lg-end gap-3 align-items-center">
          <a href="https://github.com/cortega26/retardo_cne" target="_blank" rel="noopener noreferrer"
             class="btn btn-outline-primary btn-sm fw-bold">
            <i class="fab fa-github me-2"></i>{t('footer_opensource')}
          </a>
        </div>
      </div>
    </div>
    <div class="mt-4 pt-4" style="border-top: 1px solid var(--border-subtle);">
      <div class="d-flex justify-content-center gap-4 text-muted" style="font-size: 0.7rem; font-family: var(--font-mono); text-transform: uppercase; letter-spacing: 0.1em;">
        <a href="#inicio" class="story-link">{t('nav_home')}</a>
        <a href="#cronologia" class="story-link">{t('nav_evidence')}</a>
        <a href="#sistema" class="story-link">{t('nav_context')}</a>
      </div>
    </div>
  </div>
</footer>
