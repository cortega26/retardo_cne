---
import { getLangFromUrl, useTranslations } from '../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const faqs = [
  { id: 'faqOne',   q: t('faq_1_question'), a: t('faq_1_answer'),
    sources: [{ label: 'Art. 146 y 155 LOPRE', url: 'https://pdba.georgetown.edu/Electoral/Venezuela/LOPE2009.pdf' }] },
  { id: 'faqTwo',   q: t('faq_2_question'), a: t('faq_2_answer'),
    sources: [{ label: lang === 'es' ? 'Prensa Comunitaria' : 'Prensa Comunitaria', url: 'https://prensacomunitaria.org/2024/08/venezuela-las-auditorias-para-verificar-resultados-electorales-que-no-ha-hecho-el-cne/' }] },
  { id: 'faqThree', q: t('faq_3_question'), a: t('faq_3_answer'),
    sources: [
      { label: lang === 'es' ? 'Protocolos CNE (archivo)' : 'CNE Protocols (archive)', url: 'https://web.archive.org/web/20240417122253/http://www.cne.gob.ve/web/sistema_electoral/tecnologia_electoral_auditorias.php' },
      { label: lang === 'es' ? 'CNN: auditorías no realizadas' : 'CNN: audits not performed', url: 'https://cnnespanol.cnn.com/2024/08/22/auditorias-cne-no-hizo-elecciones-presidenciales-venezuela-orix' },
    ] },
  { id: 'faqFour',  q: t('faq_4_question'), a: t('faq_4_answer'),
    sources: [{ label: 'Art. 146 y 155 LOPRE', url: 'https://pdba.georgetown.edu/Electoral/Venezuela/LOPE2009.pdf' },
              { label: lang === 'es' ? 'Panel ONU' : 'UN Panel', url: 'https://news.un.org/en/sites/news.un.org.en/files/atoms/files/Interim_Report_PoE_Venezuela_090824.pdf' }] },
  { id: 'faqFive',  q: t('faq_5_question'), a: t('faq_5_answer'),
    sources: [{ label: lang === 'es' ? 'Centro Carter, Declaración 17/08/2024' : 'Carter Center, Statement 08/17/2024', url: 'https://www.cartercenter.org/news/venezuela-073024/' }] },
  { id: 'faqSix',   q: t('faq_6_question'), a: t('faq_6_answer'),
    sources: [{ label: lang === 'es' ? 'Art. 127 Reglamento LOPRE' : 'Art. 127 LOPRE Regulations', url: 'https://pdba.georgetown.edu/Electoral/Venezuela/LOPE2009.pdf' },
              { label: lang === 'es' ? 'Resultados con Venezuela' : 'Results with Venezuela', url: 'https://resultadosconvzla.com/' }] },
  { id: 'faqSeven', q: t('faq_7_question'), a: t('faq_7_answer'),
    sources: [{ label: lang === 'es' ? 'Resultados con Venezuela' : 'Results with Venezuela', url: 'https://resultadosconvzla.com/' },
              { label: lang === 'es' ? 'Protocolos CNE (archivo)' : 'CNE Protocols (archive)', url: 'https://web.archive.org/web/20240417122253/http://www.cne.gob.ve/web/sistema_electoral/tecnologia_electoral_auditorias.php' }] },
  { id: 'faqEight', q: t('faq_8_question'), a: t('faq_8_answer'),
    sources: [{ label: lang === 'es' ? 'AP: TSJ certifica a Maduro' : 'AP: TSJ certifies Maduro', url: 'https://apnews.com/article/venezuela-election-supreme-court-certifies-maduro-39d9f3b9beb0fe96fa052e4d2a3c106b' },
              { label: 'IACHR Res. 2/2024', url: 'https://www.oas.org/en/iachr/decisions/2024/VERE2401EN.PDF' }] },
  { id: 'faqNine',  q: t('faq_9_question'), a: t('faq_9_answer'),
    sources: [{ label: lang === 'es' ? 'HRW Venezuela 2025' : 'HRW Venezuela 2025', url: 'https://www.hrw.org/world-report/2025/country-chapters/venezuela' },
              { label: lang === 'es' ? 'ACNUDH Sept. 2024' : 'OHCHR Sept. 2024', url: 'https://www.ohchr.org/en/statements-and-speeches/2024/09/venezuela-human-rights-council-receives-latest-updates-fact-finding' }] },
  { id: 'faqTen',   q: t('faq_10_question'), a: t('faq_10_answer'),
    sources: [{ label: lang === 'es' ? 'OSCE/ODIHR Informe 2020' : 'OSCE/ODIHR Report 2020', url: 'https://odihr.osce.org/odihr/elections/north-macedonia/465648' },
              { label: 'Macedonia Del Norte', url: 'https://macedoniadelnorte.com/' }] },
];

// Structured data for rich results / machine citability (audit C6).
const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqs.map((f) => ({
    '@type': 'Question',
    name: f.q,
    acceptedAnswer: { '@type': 'Answer', text: f.a },
  })),
};
---

<script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />

<section id="verificacion" class="story-section max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 my-12">
  <div class="text-center mb-12">
    <span class="section-label">{t('badge_faq')}</span>
    <h2 class="uppercase font-bold mb-6">{t('nav_verification_section')}</h2>
    <p class="story-subtitle">{t('faq_subtitle')}</p>
  </div>

  <div class="faq-list">
    {faqs.map((faq, index) => (
      <details class="faq-item" itemprop="mainEntity" itemscope="" itemtype="https://schema.org/Question">
        <summary class="faq-summary">
          <span class="me-3 font-bold" style="color: var(--text-accent);">{String(index + 1).padStart(2, '0')}.</span>
          <span itemprop="name">{faq.q}</span>
          <span class="faq-chevron" aria-hidden="true">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"></polyline></svg>
          </span>
        </summary>
        <div class="faq-content" itemprop="acceptedAnswer" itemscope="" itemtype="https://schema.org/Answer">
          <p class="mb-3" style="color: var(--text-secondary); line-height: 1.7;" itemprop="text">{faq.a}</p>
          <div class="small mt-3" style="color: var(--text-secondary);">
            <span class="font-bold me-1" style="color: var(--text-accent);">{t('sources_label')}</span>
            {faq.sources.map((s, i) => (
              <>
                {i > 0 && <span class="mx-1" aria-hidden="true">•</span>}
                <a class="story-link" href={s.url} target="_blank" rel="noopener noreferrer">{s.label}</a>
              </>
            ))}
          </div>
        </div>
      </details>
    ))}
  </div>
</section>

<style>
  /* Hide native <details> marker */
  .faq-item summary::marker,
  .faq-item summary::-webkit-details-marker {
    display: none;
  }

  /* Summary row — flex layout with number, text, chevron */
  .faq-summary {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    cursor: pointer;
    padding: 1rem 1.25rem;
    list-style: none;
    font-weight: 600;
    color: var(--text-primary);
  }

  /* Custom chevron container */
  .faq-chevron {
    display: flex;
    align-items: center;
    justify-content: center;
    margin-left: auto;
    padding-left: 1rem;
    flex-shrink: 0;
    color: var(--text-accent);
    transition: transform 0.3s ease;
  }

  /* Rotate when details is open */
  .faq-item[open] .faq-chevron {
    transform: rotate(180deg);
  }

  /* Content area */
  .faq-content {
    padding: 0 1.25rem 1.25rem;
  }

  /* FAQ item card styling */
  .faq-item {
    border: 1px solid var(--border-subtle);
    border-radius: 0.5rem;
    margin-bottom: 0.75rem;
    background: var(--bg-card);
    overflow: hidden;
  }

  .faq-item[open] {
    box-shadow: var(--shadow-card);
  }
</style>
