---
import { getLangFromUrl, useTranslations } from '../i18n/utils';
import '@fontsource/sora/400.css';
import '@fontsource/sora/600.css';
import '@fontsource/sora/700.css';
import '@fontsource/sora/800.css';
import '@fontsource/source-sans-3/400.css';
import '@fontsource/source-sans-3/500.css';
import '@fontsource/source-sans-3/600.css';
import '@fortawesome/fontawesome-free/css/all.min.css';
import '../styles/global.css';

interface Props {
	title: string;
}

const { title } = Astro.props;
const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const basePath = '/retardo_cne';
const siteOrigin = Astro.site ?? Astro.url;
const canonicalUrl = new URL(Astro.url.pathname, siteOrigin).href;
const socialImageUrl = new URL(`${basePath}/assets/img/social-preview.jpg`, siteOrigin).href;
---

<!doctype html>
<html lang={lang}>
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<meta name="color-scheme" content="light dark" />
		<meta name="description" content={t('meta_description')} />
		<meta http-equiv="X-Content-Type-Options" content="nosniff" />
		<link rel="icon" href={`${basePath}/favicon.ico`} type="image/x-icon" />
		<meta name="generator" content={Astro.generator} />
		<title>{title} — Observatorio Electoral Ciudadano</title>

		<!-- Open Graph / Social -->
		<meta property="og:type" content="website" />
		<meta property="og:url" content={canonicalUrl} />
		<meta property="og:title" content={title} />
		<meta property="og:description" content={t('meta_description')} />
		<meta property="og:image" content={socialImageUrl} />
		<meta property="og:image:width" content="1024" />
		<meta property="og:image:height" content="1024" />
		<meta property="og:image:type" content="image/jpeg" />

		<!-- Twitter -->
		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:title" content={title} />
		<meta name="twitter:description" content={t('meta_description_twitter')} />
		<meta name="twitter:image" content={socialImageUrl} />

		<!-- Bootstrap CSS (local, matching live site) -->
		<link rel="stylesheet" href={`${basePath}/assets/css/bootstrap.min.css`} />

		<!-- Modern.css — Live site design system -->
		<link rel="stylesheet" href={`${basePath}/assets/css/modern.css`} />

		<!-- Bridge — Astro component class names → modern.css equivalents -->
		<link rel="stylesheet" href={`${basePath}/assets/css/bridge.css`} />
		<script is:inline src="/retardo_cne/assets/js/theme-init.js"></script>

		<!-- Counter digit-flash animation (only changed digits animate) -->
		<style>
			@keyframes digit-flip {
				0%   { opacity: 0.4; transform: translateY(-4px) scale(0.95); }
				100% { opacity: 1;   transform: translateY(0)    scale(1); }
			}
			.counter .number.digit-flash {
				animation: digit-flip 0.25s cubic-bezier(0.2, 0.8, 0.2, 1) forwards;
			}
		</style>

	</head>
	<body class="app-shell">
		<slot />
		<script is:inline src="/retardo_cne/vendor/bootstrap/bootstrap.bundle.min.js" defer></script>
		<script is:inline src="/retardo_cne/assets/js/navbar-behavior.js" defer></script>
	</body>

</html>
