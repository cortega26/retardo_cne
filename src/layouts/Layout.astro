---
import { getLangFromUrl } from '../i18n/utils';

interface Props {
	title: string;
}

const { title } = Astro.props;
const lang = getLangFromUrl(Astro.url);
const basePath = '/retardo_cne';
---

<!doctype html>
<html lang={lang}>
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<meta name="color-scheme" content="light dark" />
		<meta name="description" content="Evidencia verificable de incumplimientos del CNE en las Elecciones 2024: plazos legales, auditorías, actas y fuentes primarias." />
		<meta http-equiv="X-Content-Type-Options" content="nosniff" />
		<link rel="icon" href={`${basePath}/favicon.ico`} type="image/x-icon" />
		<meta name="generator" content={Astro.generator} />
		<title>{title} — Observatorio Electoral Ciudadano</title>

		<!-- Open Graph / Social -->
		<meta property="og:type" content="website" />
		<meta property="og:url" content="https://cortega26.github.io/retardo_cne/" />
		<meta property="og:title" content={title} />
		<meta property="og:description" content="Evidencia verificable de incumplimientos del CNE en las Elecciones 2024: plazos legales, auditorías, actas y fuentes primarias." />
		<meta property="og:image" content={`${basePath}/assets/img/og-preview.png`} />

		<!-- Twitter -->
		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:title" content={title} />
		<meta name="twitter:description" content="Evidencia verificable de incumplimientos del CNE en las Elecciones 2024." />

		<!-- Premium Typography: Sora + Source Sans 3 (matching live site) -->
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link href="https://fonts.googleapis.com/css2?family=Sora:wght@400;600;700;800&family=Source+Sans+3:wght@400;500;600&display=swap" rel="stylesheet" />

		<!-- Font Awesome -->
		<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css" />



		<!-- Bootstrap CSS (local, matching live site) -->
		<link rel="stylesheet" href={`${basePath}/assets/css/bootstrap.min.css`} />

		<!-- Modern.css — Live site design system -->
		<link rel="stylesheet" href={`${basePath}/assets/css/modern.css`} />

		<!-- Bridge — Astro component class names → modern.css equivalents -->
		<link rel="stylesheet" href={`${basePath}/assets/css/bridge.css`} />

		<!-- Counter digit-flash animation (only changed digits animate) -->
		<style>
			@keyframes digit-flip {
				0%   { opacity: 0.4; transform: translateY(-4px) scale(0.95); }
				100% { opacity: 1;   transform: translateY(0)    scale(1); }
			}
			.counter .number.digit-flash {
				animation: digit-flip 0.25s cubic-bezier(0.2, 0.8, 0.2, 1) forwards;
			}
		</style>


		<!-- Theme Persistence Script (Head to prevent flash) -->
		<script is:inline>
			(function() {
				const theme = localStorage.getItem('theme');
				if (theme === 'dark' || (!theme && window.matchMedia('(prefers-color-scheme: dark)').matches)) {
					document.body.classList.add('dark-mode');
				} else {
					document.body.classList.remove('dark-mode');
				}
			})();
		</script>
	</head>
	<body>
		<slot />

		<!-- Bootstrap JS -->
		<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js" integrity="sha384-YvpcrYf0tY3lHB60NNkmXc5s9fDVZLESaAA55NDzOxhy9GkcIdslK1eN7N6jIeHz" crossorigin="anonymous"></script>


	</body>

</html>
