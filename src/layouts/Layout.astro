---
import { getLangFromUrl, useTranslations } from '../i18n/utils';
// Latin subset only — the site is ES/EN, so cyrillic/greek/vietnamese/latin-ext are not needed.
import '@fontsource/sora/latin-400.css';
import '@fontsource/sora/latin-600.css';
import '@fontsource/sora/latin-700.css';
import '@fontsource/sora/latin-800.css';
import '@fontsource/source-sans-3/latin-400.css';
import '@fontsource/source-sans-3/latin-500.css';
import '@fontsource/source-sans-3/latin-600.css';
import '../styles/theme.css';
import '../styles/global.css';

interface Props {
	title: string;
}

const { title } = Astro.props;
const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const basePath = '/retardo_cne';
const siteOrigin = Astro.site ?? Astro.url;
const canonicalUrl = new URL(Astro.url.pathname, siteOrigin).href;
const socialImageUrl = new URL(`${basePath}/assets/img/social-preview.jpg`, siteOrigin).href;
---

<!doctype html>
<html lang={lang}>
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<meta name="color-scheme" content="light dark" />
		<meta name="description" content={t('meta_description')} />
		<meta http-equiv="X-Content-Type-Options" content="nosniff" />
		<link rel="icon" href={`${basePath}/favicon.ico`} type="image/x-icon" />
		<meta name="generator" content={Astro.generator} />
		<title>{title} — Observatorio Electoral Ciudadano</title>

		<!-- Open Graph / Social -->
		<meta property="og:type" content="website" />
		<meta property="og:url" content={canonicalUrl} />
		<meta property="og:title" content={title} />
		<meta property="og:description" content={t('meta_description')} />
		<meta property="og:image" content={socialImageUrl} />
		<meta property="og:image:width" content="1024" />
		<meta property="og:image:height" content="1024" />
		<meta property="og:image:type" content="image/jpeg" />

		<!-- Twitter -->
		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:title" content={title} />
		<meta name="twitter:description" content={t('meta_description_twitter')} />
		<meta name="twitter:image" content={socialImageUrl} />
		<meta property="og:site_name" content="Observatorio Electoral Ciudadano" />
		<meta property="og:locale" content={lang === 'es' ? 'es_ES' : 'en_US'} />
		<meta property="og:image:alt" content={t('meta_description')} />

		<!-- Structured data -->
		<script type="application/ld+json" set:html={JSON.stringify({
			"@context": "https://schema.org",
			"@type": "WebSite",
			"name": "Observatorio Electoral Ciudadano",
			"url": "https://tooltician.com/retardo_cne/",
			"description": t('meta_description'),
			"inLanguage": ["es", "en"],
		})} />
		<script type="application/ld+json" set:html={JSON.stringify({
			"@context": "https://schema.org",
			"@type": "Organization",
			"name": "Observatorio Electoral Ciudadano",
			"url": "https://tooltician.com/retardo_cne/",
			"logo": socialImageUrl,
		})} />

		<!-- Bootstrap CSS (local, matching live site) -->
		<link rel="stylesheet" href={`${basePath}/assets/css/bootstrap.min.css`} />

		<!-- Modern.css — Live site design system -->
		<link rel="stylesheet" href={`${basePath}/vendor/css/modern.min.css`} />

		<!-- Bridge — Astro component class names → modern.css equivalents -->
		<link rel="stylesheet" href={`${basePath}/assets/css/bridge.css`} />
		<script is:inline src="/retardo_cne/assets/js/theme-init.js"></script>

		<!-- Skip-to-content link -->
		<style>
			.skip-link {
				position: absolute;
				overflow: hidden;
				clip: rect(0,0,0,0);
				width: 1px;
				height: 1px;
				margin: -1px;
				padding: 0;
				border: 0;
			}
			.skip-link:focus {
				position: fixed;
				overflow: visible;
				clip: auto;
				width: auto;
				height: auto;
				margin: 0;
				padding: 0.75rem 1.5rem;
				top: 0;
				left: 0;
				z-index: 9999;
				background: var(--color-brand-600, #2742cc);
				color: #fff;
				font-size: 1rem;
				font-weight: 700;
				text-decoration: none;
				border-radius: 0 0 8px 0;
				outline: 3px solid var(--color-brand-300, #8ea8fb);
			}
		</style>

		<!-- Counter digit-flash animation (only changed digits animate) -->
		<style>
			@keyframes digit-flip {
				0%   { opacity: 0.4; transform: translateY(-4px) scale(0.95); }
				100% { opacity: 1;   transform: translateY(0)    scale(1); }
			}
			.counter .number.digit-flash {
				animation: digit-flip 0.25s cubic-bezier(0.2, 0.8, 0.2, 1) forwards;
			}
		</style>

	<body class="app-shell">
		<a href="#main-content" class="skip-link">{lang === 'es' ? 'Ir al contenido principal' : 'Skip to main content'}</a>
		<slot />
		<script is:inline src="/retardo_cne/vendor/bootstrap/bootstrap.bundle.min.js" defer></script>
		<script is:inline src="/retardo_cne/assets/js/navbar-behavior.js" defer></script>
		<script is:inline src="/retardo_cne/assets/js/page-behavior.js" defer></script>
	</body>

</html>
