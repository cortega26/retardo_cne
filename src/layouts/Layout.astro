---
import { getLangFromUrl, useTranslations } from '../i18n/utils';
// Latin subset only — the site is ES/EN, so cyrillic/greek/vietnamese/latin-ext are not needed.
import '@fontsource/sora/latin-400.css';
import '@fontsource/sora/latin-600.css';
import '@fontsource/sora/latin-700.css';
import '@fontsource/sora/latin-800.css';
import '@fontsource/source-sans-3/latin-400.css';
import '@fontsource/source-sans-3/latin-500.css';
import '@fontsource/source-sans-3/latin-600.css';
import '../styles/theme.css';
import '../styles/base.css';
import '../styles/global.css';

interface Props {
	title: string;
	description?: string;
}

const { title, description } = Astro.props;
const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const basePath = '/retardo_cne';
const siteOrigin = Astro.site ?? Astro.url;
const canonicalUrl = new URL(Astro.url.pathname, siteOrigin).href;
const socialImageUrl = new URL(`${basePath}/assets/img/social-preview-1200x630.png`, siteOrigin).href;
const isMainPage = !Astro.url.pathname.includes('metodologia');

// Hreflang: compute ES ↔ EN alternate URLs
const pathname = Astro.url.pathname;
const enPrefix = `${basePath}/en`;
let esPath: string;
let enPath: string;
if (pathname.startsWith(enPrefix)) {
	enPath = pathname;
	esPath = pathname.replace(enPrefix, basePath) || `${basePath}/`;
} else {
	esPath = pathname;
	const relPath = pathname.slice(basePath.length) || '/';
	enPath = `${enPrefix}${relPath}`;
}
const esUrl = new URL(esPath, siteOrigin).href;
const enUrl = new URL(enPath, siteOrigin).href;

// Per-page meta description
const metaDescription = description ?? t('meta_description');
const metaDescriptionTwitter = description ?? t('meta_description_twitter');
const ogImageAlt = lang === 'es'
	? 'Observatorio Electoral Ciudadano — CNE publicó 0 actas, ciudadanía publicó 25.575'
	: 'Citizen Electoral Observatory — CNE published 0 actas, citizens published 25,575';
---

<!doctype html>
<html lang={lang}>
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<meta name="color-scheme" content="light dark" />
		<meta name="description" content={metaDescription} />
		<meta http-equiv="X-Content-Type-Options" content="nosniff" />
		<link rel="icon" href={`${basePath}/favicon.ico`} type="image/x-icon" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
		<link rel="canonical" href={canonicalUrl} />
		<link rel="alternate" hreflang="es" href={esUrl} />
		<link rel="alternate" hreflang="en" href={enUrl} />
		<link rel="alternate" hreflang="x-default" href={esUrl} />

		<!-- Open Graph / Social -->
		<meta property="og:type" content="website" />
		<meta property="og:url" content={canonicalUrl} />
		<meta property="og:title" content={title} />
		<meta property="og:description" content={metaDescription} />
		<meta property="og:image" content={socialImageUrl} />
		<meta property="og:image:width" content="1080" />
		<meta property="og:image:height" content="1080" />
		<meta property="og:image:type" content="image/png" />

		<!-- Twitter -->
		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:title" content={title} />
		<meta name="twitter:description" content={metaDescriptionTwitter} />
		<meta name="twitter:image" content={socialImageUrl} />
		<meta property="og:site_name" content="Observatorio Electoral Ciudadano" />
		<meta property="og:locale" content={lang === 'es' ? 'es_ES' : 'en_US'} />
		<meta property="og:locale:alternate" content={lang === 'es' ? 'en_US' : 'es_ES'} />
		<meta property="og:image:alt" content={ogImageAlt} />

		<!-- Structured data -->
		<script type="application/ld+json" set:html={JSON.stringify({
			"@context": "https://schema.org",
			"@type": "WebSite",
			"name": "Observatorio Electoral Ciudadano",
			"url": "https://tooltician.com/retardo_cne/",
			"description": t('meta_description'),
			"inLanguage": ["es", "en"],
		})} />
		<script type="application/ld+json" set:html={JSON.stringify({
			"@context": "https://schema.org",
			"@type": "Organization",
			"name": "Observatorio Electoral Ciudadano",
			"url": "https://tooltician.com/retardo_cne/",
			"logo": socialImageUrl,
		})} />
			{isMainPage && <script type="application/ld+json" set:html={JSON.stringify({
				"@context": "https://schema.org",
				"@type": "ClaimReview",
				"claimReviewed": lang === 'es' ? 'El CNE incumplió los procedimientos electorales legales durante las elecciones presidenciales de 2024' : 'The CNE failed to comply with legal electoral procedures during the 2024 presidential election',
				"url": canonicalUrl,
				"reviewRating": {
					"@type": "Rating",
					"worstRating": 1,
					"bestRating": 5,
					"ratingValue": 1,
					"alternateName": lang === 'es' ? 'Incumplimiento verificado' : 'Verified non-compliance'
				},
				"itemReviewed": {
					"@type": "Organization",
					"name": "Consejo Nacional Electoral (CNE)",
					"sameAs": "https://www.cne.gob.ve/"
				},
				"author": {
					"@type": "Organization",
					"name": "Observatorio Electoral Ciudadano"
				}
			})} />}


		<script is:inline src="/retardo_cne/assets/js/theme-init.js"></script>

		<!-- Reading progress bar -->
		<style>
			#read-progress {
				position: fixed;
				top: 0;
				left: 0;
				width: 0%;
				height: 3px;
				background: var(--color-brand-500, #3b5bdb);
				z-index: 9999;
				transition: width 0.1s linear;
				pointer-events: none;
			}
			@media (prefers-reduced-motion: reduce) {
				#read-progress { transition: none; }
			}
		</style>

		<!-- Skip-to-content link -->
		<style>
			.skip-link {
				position: absolute;
				overflow: hidden;
				clip: rect(0,0,0,0);
				width: 1px;
				height: 1px;
				margin: -1px;
				padding: 0;
				border: 0;
			}
			.skip-link:focus {
				position: fixed;
				overflow: visible;
				clip: auto;
				width: auto;
				height: auto;
				margin: 0;
				padding: 0.75rem 1.5rem;
				top: 0;
				left: 0;
				z-index: 9999;
				background: var(--color-brand-600, #2742cc);
				color: #fff;
				font-size: 1rem;
				font-weight: 700;
				text-decoration: none;
				border-radius: 0 0 8px 0;
				outline: 3px solid var(--color-brand-300, #8ea8fb);
			}
		</style>

		<!-- Counter digit-flash animation (only changed digits animate) -->
		<style>
			@keyframes digit-flip {
				0%   { opacity: 0.4; transform: translateY(-4px) scale(0.95); }
				100% { opacity: 1;   transform: translateY(0)    scale(1); }
			}
			.counter .number.digit-flash {
				animation: digit-flip 0.25s cubic-bezier(0.2, 0.8, 0.2, 1) forwards;
			}
		</style>
	</head>

	<body class="app-shell">
		<div id="read-progress" role="progressbar" aria-hidden="true"></div>
		<a href="#main-content" class="skip-link">{lang === 'es' ? 'Ir al contenido principal' : 'Skip to main content'}</a>
		<slot />
		<script is:inline src="/retardo_cne/assets/js/navbar-behavior.js" defer></script>
		<script is:inline src="/retardo_cne/assets/js/page-behavior.js" defer></script>
		<script>
			(function () {
				const bar = document.getElementById('read-progress');
				if (!bar) return;
				function update() {
					if (!bar) return;
					const scrolled = window.scrollY;
					const total = document.documentElement.scrollHeight - window.innerHeight;
					bar.style.width = total > 0 ? (scrolled / total * 100).toFixed(1) + '%' : '0%';
				}
				window.addEventListener('scroll', update, { passive: true });
				update();
			})();
		</script>
	</body>

</html>
